/*
* PURCHASE
*/

PURCHASE_SPRITESET_WAGON(coach_Narrow_Gen6_GoldenPass_Express_Control_Coach, "gfx/Coaches/Gen6/GoldenPass_Express_Control_Coach_Purchase.xpm", 1, 1)

/*
* Vehicle
*/

spriteset(spriteset_coach_Narrow_Gen6_GoldenPass_Express_Control_Coach_fwd, "gfx/Coaches/Gen6/GoldenPass_Express_Control_Coach.xpm") {
    template_2cc_wagons(1, 1)
}

spriteset(spriteset_coach_Narrow_Gen6_GoldenPass_Express_Control_Coach_bwd, "gfx/Coaches/Gen6/GoldenPass_Express_Control_Coach.xpm") {
    template_2cc_wagons(179, 1)
}

switch(FEAT_TRAINS, PARENT, switch_coach_Narrow_Gen6_GoldenPass_Express_Control_Coach_graphics, vehicle_is_reversed) {
    1: spriteset_coach_Narrow_Gen6_GoldenPass_Express_Control_Coach_bwd;
    0: spriteset_coach_Narrow_Gen6_GoldenPass_Express_Control_Coach_fwd;
}

/*
* Cargo capacity
*/

ENGINECAPACITYSWITCH(VEHIDCODE)

//Add defined switches

RUNNINGCOSTENGINESWITCH

EXPANDEDPURCHASETEXTSWITCH(VEHIDCODE)