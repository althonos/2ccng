#define GEN3_FLAT_LIVERY(NAME, L, OFFSET) \
	spriteset(spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S1, format_string("build/gfx/Gen3_Flat_Wagon_%s.png", #NAME)) { \
		template_2cc_wagons(OFFSET, 1) \
	} \
	spriteset(spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S2, format_string("build/gfx//Gen3_Flat_Wagon_%s.png", #NAME)) { \
		template_2cc_wagons(OFFSET, 27) \
	} \
	spriteset(spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S3, format_string("build/gfx//Gen3_Flat_Wagon_%s.png", #NAME)) { \
		template_2cc_wagons(OFFSET, 53) \
	} \
	spritegroup spritegroup_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L { \
		loading: [spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S1, spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S2, spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S3]; \
		loaded: [spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S1, spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S2, spriteset_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _ ## L ## _S3]; \
	}

#define GEN3_FLAT_WAGON(NAME) \
	GEN3_FLAT_LIVERY(NAME, L1, 1) \
	GEN3_FLAT_LIVERY(NAME, L2, 179) \
	GEN3_FLAT_LIVERY(NAME, L3, 357) \
	GEN3_FLAT_LIVERY(NAME, L4, 535) \
	random_switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _livery) { \
		7: spritegroup_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _L1; \
		/*1: spritegroup_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _L2;*/ \
		/*1: spritegroup_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _L3;*/ \
		/*1: spritegroup_wagon_Narrow_Gen3_Flat_Wagon_ ## NAME ## _L4;*/ \
	}


// GEN3_FLAT_WAGON(Barrels)
GEN3_FLAT_WAGON(Crates)
GEN3_FLAT_WAGON(Explosives)
// GEN3_FLAT_WAGON(Copper)
GEN3_FLAT_WAGON(Planks)
// GEN3_FLAT_WAGON(Machinery)
GEN3_FLAT_WAGON(Wood)
// GEN3_FLAT_WAGON(Paper)
// GEN3_FLAT_WAGON(Steel_Coil)
// GEN3_FLAT_WAGON(Steel_Wire)
GEN3_FLAT_WAGON(Steel_Sheets)
// GEN3_FLAT_WAGON(Tyres)
GEN3_FLAT_WAGON(Tractor)

/*
* PURCHASE
*/

spriteset(spriteset_wagon_Narrow_Gen3_Flat_Wagon_purchase, "gfx/Wagons/Gen3/Flat_Wagon/Purchase.png") {
	template_purchase_wagon(1, 1)
}

// Steel has multiple liveries
random_switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_livery) {
	// 2: switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_Coil_livery;
	// 2: switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_Wire_livery;
	2: switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_Sheets_livery;
}

// Goods and Engineering/Farming Supplies have multiple liveries
random_switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen3_Flat_Wagon_Supplies_livery) {
	7: switch_wagon_Narrow_Gen3_Flat_Wagon_Crates_livery;
	3: switch_wagon_Narrow_Gen3_Flat_Wagon_Tractor_livery;
}

// Building materials can be planks, steel or copper
random_switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen3_Flat_Wagon_Building_Materials_livery) {
	2: switch_wagon_Narrow_Gen3_Flat_Wagon_Planks_livery;
	2: switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_livery;
// 	1: switch_wagon_Narrow_Gen3_Flat_Wagon_Copper_livery;
}

switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen3_Flat_Wagon_Default_livery, hasbit(cargo_type_in_veh, CC_LIQUID)) {
// 	1: switch_wagon_Narrow_Gen3_Flat_Wagon_Barrels_livery;	// Liquids shown as barrels
// 	0: switch_wagon_Narrow_Gen3_Flat_Wagon_Crates_livery;	// Piece goods shown as crates
	switch_wagon_Narrow_Gen3_Flat_Wagon_Crates_livery;
}

switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen3_Flat_Wagon_cargo_selection, cargo_type_in_veh) {
	/* Goods */
	// GOOD: switch_wagon_Narrow_Gen3_Flat_Wagon_Goods_livery;

	/* Farming / Engineering supplies */
	ENSP: switch_wagon_Narrow_Gen3_Flat_Wagon_Supplies_livery;
	FMSP: switch_wagon_Narrow_Gen3_Flat_Wagon_Supplies_livery;
	
	WOOD: switch_wagon_Narrow_Gen3_Flat_Wagon_Wood_livery;
	BOOM: switch_wagon_Narrow_Gen3_Flat_Wagon_Explosives_livery;
	// COPR: switch_wagon_Narrow_Gen3_Flat_Wagon_Copper_livery;
	BDMT: switch_wagon_Narrow_Gen3_Flat_Wagon_Building_Materials_livery;
	WDPR: switch_wagon_Narrow_Gen3_Flat_Wagon_Planks_livery;
	
	// PAPR: switch_wagon_Narrow_Gen3_Flat_Wagon_Paper_livery;		// Paper
	// PACK: switch_wagon_Narrow_Gen3_Flat_Wagon_Paper_livery;  	// Packaging
	
	// TYRE: switch_wagon_Narrow_Gen3_Flat_Wagon_Tyres_livery;		// Rubber Parts, Tyres
	
	STEL: switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_livery;
	STAL: switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_livery;
	STSH: switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_Sheets_livery;
	// STWR: switch_wagon_Narrow_Gen3_Flat_Wagon_Steel_Wire_livery;

	switch_wagon_Narrow_Gen3_Flat_Wagon_Default_livery; 
}

//Add defined switches 

ENGINECAPACITYSWITCH(VEHIDCODE)

RUNNINGCOSTENGINESWITCH

PURCHASETEXTSWITCH