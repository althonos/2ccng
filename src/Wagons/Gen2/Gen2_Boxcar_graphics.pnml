#define GEN2_BOXCAR_LIVERY(NAME, L, OFFSET) \
	spriteset(spriteset_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _ ## L ## _S1, format_string("build/gfx/Gen2_Boxcar_%s.png", #NAME)) { \
		template_2cc_wagons(OFFSET, 1) \
	} \
	spriteset(spriteset_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _ ## L ## _S2, format_string("build/gfx/Gen2_Boxcar_%s.png", #NAME)) { \
		template_2cc_wagons(OFFSET, 27) \
	} \
	spriteset(spriteset_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _ ## L ## _S3, format_string("build/gfx/Gen2_Boxcar_%s.png", #NAME)) { \
		template_2cc_wagons(OFFSET, 53) \
	} \
	spritegroup spritegroup_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _ ## L { \
		loading: spriteset_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _ ## L ## _S3; \
		loaded: [spriteset_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _ ## L ## _S1, spriteset_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _ ## L ## _S2]; \
	}

#define GEN2_BOXCAR(NAME) \
	GEN2_BOXCAR_LIVERY(NAME, L1, 1) \
	/*GEN2_BOXCAR_LIVERY(NAME, L2, 179)*/ \
	/*GEN2_BOXCAR_LIVERY(NAME, L3, 357)*/ \
	/*GEN2_BOXCAR_LIVERY(NAME, L4, 535)*/ \
	random_switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _livery) { \
		7: spritegroup_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _L1; \
		/*1: spritegroup_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _L2;*/ \
		/*1: spritegroup_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _L3;*/ \
		/*1: spritegroup_wagon_Narrow_Gen2_Boxcar_ ## NAME ## _L4;*/ \
	}

/*
* PURCHASE
*/

spriteset(spriteset_wagon_Narrow_Gen2_Boxcar_purchase, "gfx/Wagons/Gen2/Boxcar/Purchase.png") {
	template_purchase_wagon(1, 1)
}

/*
* CARGO VARIATIONS
*/

GEN2_BOXCAR(Standard)
// GEN2_BOXCAR(Armoured)
// GEN2_BOXCAR(Livestock)
// GEN2_BOXCAR(Reefer)

//Goods have multiple liveries
random_switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen2_Boxcar_Goods_livery) {
	7: switch_wagon_Narrow_Gen2_Boxcar_Standard_livery;
	// 3: switch_wagon_Narrow_Gen2_Boxcar_Reefer_livery;
}

switch(FEAT_TRAINS, SELF, switch_wagon_Narrow_Gen2_Boxcar_cargo_selection, cargo_type_in_veh) {
	// LVST: switch_wagon_Narrow_Gen2_Boxcar_Livestock_livery;
	
	// GOOD: switch_wagon_Narrow_Gen2_Boxcar_Goods_livery;
	
	// VALU: switch_wagon_Narrow_Gen2_Boxcar_Armoured_livery;
	// GOLD: switch_wagon_Narrow_Gen2_Boxcar_Armoured_livery;
	// DIAM: switch_wagon_Narrow_Gen2_Boxcar_Armoured_livery;

	// FOOD: switch_wagon_Narrow_Gen2_Boxcar_Reefer_livery;
	// FRUT: switch_wagon_Narrow_Gen2_Boxcar_Reefer_livery;
	// FZDR: switch_wagon_Narrow_Gen2_Boxcar_Reefer_livery;
	// BEER: switch_wagon_Narrow_Gen2_Boxcar_Reefer_livery;
	// FISH: switch_wagon_Narrow_Gen2_Boxcar_Reefer_livery;

	switch_wagon_Narrow_Gen2_Boxcar_Standard_livery; 
}

