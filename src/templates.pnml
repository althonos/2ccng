//Purchase templates
//Engines
template template_purchase_flag_and_power(x, y) {
    //[left_x, upper_y, width, height, offset_x, offset_y]
    [x, y,  87, 12, -25, -8]
}

template template_purchase_flag_only(x, y) {
    //[left_x, upper_y, width, height, offset_x, offset_y]
    [x, y,  73, 12, -25, -8]
}

template template_purchase_none(x, y) {
    //[left_x, upper_y, width, height, offset_x, offset_y]
    [x, y,  53, 12, -25, -8]
}

//Dualheaded Engines
template template_purchase_dualheaded_flag_and_power(x,y) {
